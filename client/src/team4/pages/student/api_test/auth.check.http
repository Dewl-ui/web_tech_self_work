@baseUrl = https://todu.mn/bs/lms/v1
@accessToken = RlJFjNFirdNPyg2hcvJLzQ

### 1. Login with email and password
POST {{baseUrl}}/token/email
Content-Type: application/json

{
  "email": "admin@must.edu.mn",
  "password": "123",
  "push_token": "fcm_token_optional"
}

### 2. Login with phone and password
POST {{baseUrl}}/token/phone
Content-Type: application/json

{
  "phone": "99119911",
  "password": "secret123",
  "push_token": "fcm_token_optional"
}

### 3. Send OTP to email (for passwordless login)
POST {{baseUrl}}/otp/email
Content-Type: application/json

{
  "email": "student@example.com"
}

### 4. Login with email + OTP code
POST {{baseUrl}}/otp/email/login
Content-Type: application/json

{
  "email": "student@example.com",
  "code": "123456",
  "push_token": "fcm_token_optional"
}

### 5. Send OTP to phone
POST {{baseUrl}}/otp/phone
Content-Type: application/json

{
  "phone": "99119911"
}

### 6. Login with phone + OTP code
POST {{baseUrl}}/otp/phone/login
Content-Type: application/json

{
  "phone": "99119911",
  "code": "123456",
  "push_token": "fcm_token_optional"
}

### 7. Refresh access token
POST {{baseUrl}}/token/refresh
Content-Type: application/json

{
  "refresh_token": "your_refresh_token_here"
}

### 8. Logout
DELETE {{baseUrl}}/token
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### 9. Change own password (authenticated)
PUT {{baseUrl}}/users/me/password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "password": "old_password",
  "new_password": "new_strong_password"
}