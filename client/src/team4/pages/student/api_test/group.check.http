### Group Management API Check File
### Base URL: https://todu.mn/bs/lms/v1
### Supports: List groups per course, group detail, course members by group.
### Assigning users to groups is done via course user update (see courseUser.check.http).
###
### ── USED IN: studentGroupApi.js ──────────────────────────────────────────────

@baseUrl = https://todu.mn/bs/lms/v1
@courseId = 204
@groupId = 86

### 1. List all groups in a course
### → Used by: getGroupsByCourse(courseId)
GET {{baseUrl}}/courses/{{courseId}}/groups
Authorization: Bearer {{accessToken}}

# HTTP/1.1 200
# {
#   "items": [
#     {
#       "id": 86,
#       "course_id": 204,
#       "name": "5-5",
#       "created_by": 0,
#       "created_on": "2025-12-05T08:37:46.866217Z",
#       "updated_by": 0,
#       "updated_on": "2025-12-05T08:37:46.866217Z",
#       "priority": 1
#     },
#     {
#       "id": 87,
#       "course_id": 204,
#       "name": "5-6",
#       "priority": 1
#     }
#   ],
#   "hasMore": false,
#   "limit": 25,
#   "offset": 0,
#   "count": 2
# }

### 2. Get group details by ID
### → Used by: getGroupDetail(groupId)
GET {{baseUrl}}/groups/{{groupId}}
Authorization: Bearer {{accessToken}}

# HTTP/1.1 200
# {
#   "id": 86,
#   "course_id": 204,
#   "name": "5-5",
#   "priority": 1,
#   "created_by": 0,
#   "created_on": "2025-12-05T08:37:46.866217Z",
#   "updated_by": 0,
#   "updated_on": "2025-12-05T08:37:46.866217Z",
#   "links": [{ "rel": "collection", "href": "https://todu.mn/bs/lms/v1/groups/" }]
# }

### 3. List users enrolled in a course (with group assignment)
### → Used by: getCourseMembers(courseId)
### Note: student can only read — not write — via this endpoint.
GET {{baseUrl}}/courses/{{courseId}}/users
Authorization: Bearer {{accessToken}}

# HTTP/1.1 200
# {
#   "items": [
#     {
#       "user_id": 578,
#       "group_id": 86,
#       "group": { "id": 86, "name": "5-5" },
#       "user": {
#         "id": 578,
#         "first_name": "Дэлгэрмаа",
#         "last_name": "Отгонбаатар",
#         "username": "b232270024",
#         "email": "b232270024@must.edu.mn",
#         "picture": "no-image.jpg"
#       }
#     },
#     {
#       "user_id": 579,
#       "group_id": null,
#       "group": { "id": null, "name": null },
#       "user": { "id": 579, "first_name": "Оюунжаргал", ... }
#     }
#   ],
#   "hasMore": false,
#   "count": 25
# }

### ── WRITE ENDPOINTS (admin/teacher only) ────────────────────────────────────

### 4. Create a new group in a course  [ADMIN/TEACHER]
POST {{baseUrl}}/courses/{{courseId}}/groups
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Group A",
  "priority": 1
}

### 5. Update group  [ADMIN/TEACHER]
PUT {{baseUrl}}/groups/{{groupId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Group Alpha",
  "priority": 2,
  "course_id": "{{courseId}}"
}

### 6. Delete a group  [ADMIN/TEACHER]
DELETE {{baseUrl}}/groups/{{groupId}}
Authorization: Bearer {{accessToken}}